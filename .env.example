# ─────────────────────────────────────────────────────────────────────────────
# FieldText environment variables
# Copy to `.env.local` for local dev; set the same values in Vercel for prod.
# NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Twilio (Programmable Messaging) — the ONE designated business number ─────
# TODO: fill in from https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# TODO: the A2P 10DLC-registered business number in E.164, e.g. +14155551234
TWILIO_FROM_NUMBER=

# ── LLM (Anthropic Claude) ──────────────────────────────────────────────────
# TODO: API key from https://console.anthropic.com
ANTHROPIC_API_KEY=
# Model is swappable here (parseMessage() is model-agnostic). Default is the most
# capable. For a high-volume SMS parser, claude-haiku-4-5 is far cheaper — see README.
#   claude-opus-4-8  ($5 / $25 per 1M)   claude-sonnet-4-6 ($3 / $15)   claude-haiku-4-5 ($1 / $5)
ANTHROPIC_MODEL=claude-opus-4-8

# ── Security ────────────────────────────────────────────────────────────────
# Random string. Vercel Cron sends it automatically as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=
# Password for the /dashboard owner login.
DASHBOARD_PASSWORD=

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# The default business the dashboard/cron operate on (matches businesses.slug).
DEFAULT_BUSINESS_SLUG=green-acres

# ── Billing / usage logging (optional, on by default) ───────────────────────
# Global kill-switch; set false to disable usage/cost logging entirely.
# (Per-business toggle also lives in businesses.settings.billing_enabled.)
BILLING_ENABLED=true
# USD per Twilio SMS segment (US default ~ $0.0079). Adjust to your Twilio pricing.
SMS_COST_PER_SEGMENT=0.0079
